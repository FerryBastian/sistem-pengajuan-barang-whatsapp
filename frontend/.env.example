# React Vite environment example
# Salin file ini menjadi .env di root project, lalu sesuaikan URL sesuai APP_URL Laravel Anda.
# VITE harus menjadi prefix agar bisa diakses di client.

# Prefix API sesuai routes Laravel: /api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Host untuk CSRF cookie Sanctum (APP_URL Laravel tanpa /api)
VITE_BACKEND_APP_URL=http://localhost:8000

# Google OAuth Client ID (untuk Google Identity Services)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
